# Database
DATABASE_URL=postgresql://gigshield:gigshield123@localhost:5432/gigshield_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Weather APIs
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHERSTACK_API_KEY=your-weatherstack-backup-api-key

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Twilio (WhatsApp Business API)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://your-domain.com/webhooks/whatsapp

# Razorpay (Payment Gateway - Test Mode)
RAZORPAY_KEY_ID=your-razorpay-test-key-id
RAZORPAY_KEY_SECRET=your-razorpay-test-key-secret

# SendGrid (Email Service)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@gigshield.app

# Application Configuration
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Background Jobs
WEATHER_CHECK_INTERVAL_SECONDS=300
CLAIM_PROCESSING_INTERVAL_SECONDS=60

# Insurance Configuration
BASE_PREMIUM_WEEKLY=40
MIN_PREMIUM_WEEKLY=35
MAX_PREMIUM_WEEKLY=80
DEFAULT_COVERAGE_DAILY=800
